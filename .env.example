# Birth Chart Generator runtime contract

# production, development, or test. Staging is intentionally not supported.
APP_ENV=development
NEXT_PUBLIC_APP_NAME="Birth Chart Generator"

# Required only when a feature needs persistence.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/birth_chart_generator_dev

# Local Docker database defaults. Production values are provided by the runtime.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=birth_chart_generator_dev
POSTGRES_PORT=5432
