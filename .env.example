# Astriq runtime contract

# production, development, or test. Staging is intentionally not supported.
APP_ENV=development
NEXT_PUBLIC_APP_NAME="Astriq"
# Public site URL used for Open Graph and other absolute metadata links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Required only when a feature needs persistence.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/birth_chart_generator_dev

# Auth session signing key. Use a long random string in production.
AUTH_SESSION_SECRET=change-this-secret-in-production

# Per-user chart generation quota.
MAX_CHARTS_PER_USER=3

# Birth chart engine backend (C++ CLI + NAIF CSPICE / DE442s).
# Local defaults are relative to the repo root. Production compose overrides
# these with absolute /app/... paths inside the container.
KUNDLI_ENGINE_BACKEND=jpl_spice
KUNDLI_ENGINE_BIN=services/astrology-engine/bin/kundli-engine
KUNDLI_SPICE_KERNEL_DIR=services/astrology-engine/assets/jpl

# Local Docker database defaults. Production uses the compose `postgres`
# service and stores real credentials in secrets/production.enc.yaml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=birth_chart_generator_dev
POSTGRES_PORT=5432
