{
  "name": "birth-chart-generator",
  "version": "0.1.0",
  "description": "Production Next.js app for birth chart generation.",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:procs": "mprocs",
    "build": "pnpm build:engine && next build",
    "build:engine": "node scripts/build-astrology-engine.mjs",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm db:generate && tsc --noEmit && pnpm --filter database type-check",
    "test": "pnpm test:engine && vitest run",
    "test:unit": "pnpm test:engine && vitest run",
    "test:engine": "pnpm build:engine && services/astrology-engine/bin/kundli-engine-tests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ephemeris:download": "node scripts/download-jpl-spice-assets.mjs",
    "docker:dev": "node --import tsx scripts/start-dev-database.ts",
    "docker:dev:down": "docker compose -f infrastructure/docker/docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f infrastructure/docker/docker-compose.dev.yml logs -f",
    "docker:prod": "docker compose -f infrastructure/docker/docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f infrastructure/docker/docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f infrastructure/docker/docker-compose.prod.yml logs -f app",
    "db:studio": "pnpm --filter database db:studio",
    "db:generate": "pnpm --filter database db:generate",
    "db:migrate": "pnpm --filter database db:migrate",
    "db:deploy": "pnpm --filter database db:deploy",
    "db:push": "pnpm --filter database db:push",
    "db:seed": "pnpm --filter database db:seed",
    "db:check-migration": "node --import tsx scripts/check-schema-migration.ts",
    "secrets:decrypt": "SOPS_AGE_KEY_FILE=.age-key.txt make decrypt-local",
    "secrets:decrypt:production": "SOPS_AGE_KEY_FILE=.age-key.txt make decrypt-production",
    "secrets:edit": "SOPS_AGE_KEY_FILE=.age-key.txt make edit-local",
    "secrets:edit:production": "SOPS_AGE_KEY_FILE=.age-key.txt make edit-production",
    "secrets:updatekeys": "SOPS_AGE_KEY_FILE=.age-key.txt make update-secret-keys",
    "prepare": "husky"
  },
  "dependencies": {
    "all-the-cities": "^3.1.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mprocs": "^0.9.6",
    "prettier": "^3.9.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af"
}
